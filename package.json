{
	"name": "retrozetro-monorepo",
	"type": "module",
	"version": "1.0.0",
	"private": true,
	"packageManager": "npm@11.12.0",
	"description": "Monorepo for retro zetro comics",
	"author": "Jacob Anderson",
	"license": "ISC",
	"keywords": [],
	"workspaces": [
		"front-end",
		"back-end"
	],
	"scripts": {
		"build": "npm run -w front-end build && npm run -w back-end build",
		"dev": "npm run -w front-end dev",
		"server": "npm run -w back-end server",
		"serve": "npm run -w front-end serve",
		"lint-server": "npm run -w back-end lint-fix && npm run -w back-end server",
		"lint-serve": "npm run -w front-end lint-fix && npm run -w front-end serve",
		"lint": "npm run -w front-end lint && npm run -w back-end lint",
		"lint-fix": "npm run -w front-end lint-fix && npm run -w back-end lint-fix",
		"typecheck": "npm run -w front-end typecheck && npm run -w back-end typecheck",
		"clean": "sudo rm -rf node_modules dist package-lock.json **/node_modules **/dist **/package-lock.json",
		"up": "taze major -I && npm run -w front-end up && npm run -w back-end up"
	},
	"devDependencies": {
		"@antfu/eslint-config": "^7.7.3",
		"@unhead/dom": "2.1.13",
		"@typescript-eslint/eslint-plugin": "^8.57.1",
		"@typescript-eslint/parser": "^8.57.1",
		"eslint": "^10.1.0",
		"eslint-config-prettier": "^10.1.8",
		"eslint-plugin-prettier": "^5.5.5",
		"eslint-plugin-vue": "^10.8.0",
		"follow-redirects": "1.16.0",
		"globals": "^17.4.0",
		"lodash": "4.18.1",
		"path-to-regexp": "8.4.2",
		"prettier": "^3.8.1",
		"taze": "^19.10.0",
		"typescript": "^5.9.3",
		"unhead": "2.1.13",
		"vite": "8.0.10"
	},
	"overrides": {
		"brace-expansion": "5.0.5",
		"defu": "6.1.7",
		"follow-redirects": "1.16.0",
		"lodash": "4.18.1",
		"path-to-regexp": "8.4.2",
		"picomatch": "4.0.4",
		"anymatch": {
			"picomatch": "2.3.2"
		},
		"micromatch": {
			"picomatch": "2.3.2"
		},
		"readdirp": {
			"picomatch": "2.3.2"
		}
	},
	"dependencies": {}
}
